{
  "name": "matthew-freed-pottery-web",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean": "rm -rf dist",
    "eleventy:default": "npx eleventy",
    "eleventy:watch": "npx eleventy --watch",
    "eleventy:serve": "npx eleventy --serve",
    "styles:dev": "postcss src/styles/main.css --output dist/styles/main.css",
    "styles:watch": "postcss src/styles/main.css --output dist/styles/main.css --watch",
    "styles:prod": "postcss src/styles/main.css --output dist/styles/main.css",
    "dev": "npm-run-all clean styles:dev eleventy:default --parallel styles:watch eleventy:watch eleventy:serve --print-label",
    "build": "npm-run-all clean styles:prod eleventy:default --print-label"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "browserslist": [
    "defaults"
  ],
  "dependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@tailwindcss/postcss": "^4.3.1",
    "cssnano": "^8.0.0",
    "eleventy-plugin-pwa-v2": "^1.0.2",
    "eleventy-plugin-seo": "^0.5.2",
    "luxon": "^3.7.2",
    "npm-run-all2": "^9.0.2",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.3.1"
  }
}
