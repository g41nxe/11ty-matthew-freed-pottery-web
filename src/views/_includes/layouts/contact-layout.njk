---
layout: base
---

<section class="mx-auto max-w-6xl px-6 py-12">
    <p class="cap-label text-blue">Get in touch</p>
    <h1 class="mt-3 font-display text-4xl font-black text-ink">{{ headline | default(title) }}</h1>
    {% if subheadline %}<p class="mt-4 max-w-xl text-base leading-relaxed text-muted">{{ subheadline }}</p>{% endif %}
    <div class="mt-10 flex flex-col gap-10 md:flex-row">
        <div class="md:flex-1">{% include "contact-form.njk" %}</div>
        <div class="md:flex-1">{% include "contact-details.njk" %}</div>
    </div>
</section>
