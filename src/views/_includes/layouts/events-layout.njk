---
layout: base
---

<section class="mx-auto max-w-6xl px-6 pt-12">
    <p class="cap-label text-blue">{{ intro.eyebrow }}</p>
    <h1 class="mt-3 font-display text-4xl font-black text-ink">{{ intro.title }}</h1>
    {% if rhythm %}<p class="mt-4 max-w-2xl text-base leading-relaxed text-muted">{{ rhythm }}</p>{% endif %}
</section>

<div class="mx-auto flex max-w-6xl flex-col gap-8 px-6 py-10 lg:flex-row">
    <div class="lg:flex-[1.4]">
        {% set upcoming = events.events | filterFuture %}
        {% set special = upcoming | specialEvents %}
        {% set markets = upcoming | groupByVenue %}

        {% if special.length %}
        <p class="cap-label mb-4 text-blue">Special events</p>
        {% for event in special %}
        <article class="mb-4 flex gap-4 rounded-xl border border-hairline bg-white p-5">
            <div class="flex h-fit flex-none flex-col items-center rounded-lg px-4 py-2 {% if event.atStudio %}bg-sand{% else %}bg-tile{% endif %}">
                <span class="cap-label text-[11px] {% if event.atStudio %}text-ink{% else %}text-soft{% endif %}">{{ event.date | date("MMM") }}</span>
                <span class="font-display text-xl font-black text-ink">{{ event.date | date("d") }}{% if event.multi_day_event and event.end_date != event.date %}–{{ event.end_date | date("d") }}{% endif %}</span>
            </div>
            <div>
                <h2 class="font-display text-xl font-black text-ink">
                    {{ event.name }}
                    {% if event.atStudio %}<span class="cap-label ml-2 text-[11px] text-sand">At my studio</span>{% endif %}
                </h2>
                <p class="mt-1 text-sm text-muted">{{ event.location }} · {{ event.time }}</p>
                {% if event.content.body %}<p class="mt-2 text-sm leading-relaxed text-muted">{{ event.content.body }}</p>{% endif %}
                {% if event.gmaps %}<a href="https://www.google.com/maps/search/?api=1&query={{ event.gmaps | urlencode }}" class="link-underline mt-3 inline-block text-sm">Directions</a>{% endif %}
            </div>
        </article>
        {% endfor %}
        {% endif %}

        {% if markets.length %}
        <p class="cap-label mb-4 text-blue{% if special.length %} mt-10{% endif %}">Market schedule</p>
        {% for group in markets %}
        <article class="mb-4 rounded-xl border border-hairline bg-white p-5">
            <div class="flex flex-wrap items-baseline justify-between gap-2">
                <h2 class="font-display text-xl font-black text-ink">{{ group.name }}</h2>
                {% if group.first.gmaps %}<a href="https://www.google.com/maps/search/?api=1&query={{ group.first.gmaps | urlencode }}" class="link-underline text-sm">Directions</a>{% endif %}
            </div>
            <p class="mt-1 text-sm text-muted">{{ group.first.location }} · {{ group.first.time }}</p>
            {% if group.first.content.body %}<p class="mt-2 text-sm leading-relaxed text-muted">{{ group.first.content.body }}</p>{% endif %}
            <div class="mt-4 flex flex-wrap items-center gap-2">
                {% for d in group.dates %}
                <span class="rounded-lg px-3 py-1.5 text-sm font-medium {% if loop.first %}bg-sand{% else %}bg-tile{% endif %} text-ink"{% if loop.first %} title="Next date"{% endif %}>{{ d | date("MMM d") }}</span>
                {% endfor %}
            </div>
        </article>
        {% endfor %}
        {% endif %}

        {% if not special.length and not markets.length %}
        <p class="rounded-xl border border-hairline bg-white p-6 text-base text-muted">{{ no_events }}</p>
        {% endif %}
    </div>

    <div class="lg:flex-1">
        <p class="cap-label mb-4 text-blue">Latest from the studio</p>
        {% set latestNews = news.news | sortByDate | first %}
        {% if latestNews or studio.title %}
        <div class="overflow-hidden rounded-xl border border-hairline bg-white lg:sticky lg:top-20">
            {% if latestNews %}
            <div>
                {% if latestNews.image.url %}
                {% img latestNews.image.url, latestNews.image.alt, "(min-width: 1024px) 30vw, 100vw", "aspect-[4/3] w-full object-cover" %}
                {% endif %}
                <div class="p-6">
                    <p class="cap-label text-[11px] text-soft">From the studio &middot; {{ latestNews.date | date("MMM d") }}</p>
                    <h2 class="mt-2 font-display text-xl font-black text-ink">{{ latestNews.content.title }}</h2>
                    <p class="mt-3 text-sm leading-relaxed text-muted">{{ latestNews.content.body | safe }}</p>
                    {% img "images/signature.jpg", "Cheers, Matthew", "144px", "mt-4 ml-auto block h-auto w-32" %}
                </div>
            </div>
            {% endif %}

            {% if latestNews and studio.title %}
            <div class="mx-6 border-t border-hairline"></div>
            {% endif %}

            {% if studio.title %}
            <div class="p-6">
                <h2 class="font-display text-base font-black text-ink">{{ studio.title }}</h2>
                <p class="mt-1.5 text-sm leading-relaxed text-muted">{{ studio.text }}</p>
                <a href="{{ studio.cta.url }}" class="btn-primary mt-3 inline-block px-5 py-2.5 text-sm">{{ studio.cta.label }}</a>
                {% if studio.footnote %}<p class="mt-3 text-xs leading-relaxed text-soft">{{ studio.footnote }}</p>{% endif %}
            </div>
            {% endif %}
        </div>
        {% endif %}
    </div>
</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {% for event in events.events | filterFuture %}
    {
      "@type": "Event",
      "name": {{ event.name | dump | safe }},
      "startDate": "{{ event.date | date("yyyy-MM-dd") }}",
      "endDate": "{{ event.end_date | date("yyyy-MM-dd") }}",
      "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
      "location": {
        "@type": "Place",
        "name": {{ event.location | dump | safe }},
        "address": {{ event.gmaps | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
