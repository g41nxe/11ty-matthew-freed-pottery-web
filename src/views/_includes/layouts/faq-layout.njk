---
layout: base
---

<section class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="font-display text-4xl font-black text-ink">{{ headline | default(title) }}</h1>
    {% if intro %}<p class="mt-4 text-base leading-relaxed text-muted">{{ intro }}</p>{% endif %}

    {% for section in faq.sections %}
    <h2 class="cap-label mt-10 text-blue">{{ section.title }}</h2>
    <div class="mt-2">
        {% for q in section.questions %}
        <details class="group border-b border-hairline py-4">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-lg font-black text-ink">
                {{ q.title }}
                <svg class="flex-none transition-transform group-open:rotate-45" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
            </summary>
            <p class="mt-3 text-base leading-relaxed text-muted">{{ q.body | nl2br | safe }}</p>
        </details>
        {% endfor %}
    </div>
    {% endfor %}
</section>
