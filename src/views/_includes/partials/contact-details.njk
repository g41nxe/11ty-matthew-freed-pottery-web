<h2 class="font-display text-2xl font-black text-ink">
    {{ headline }}<br/>
    <span class="text-blue">{{ subheadline }}</span>
</h2>

<ul class="mt-4 flex flex-row justify-start gap-4">
    <li>
        <a href="{{ global.socialmedia.services.instagram.url }}" target="_blank" aria-label="Instagram" class="text-muted transition-colors hover:text-blue">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="0.8" fill="currentColor"/></svg>
        </a>
    </li>
    <li>
        <a href="{{ global.socialmedia.services.facebook.url }}" target="_blank" aria-label="Facebook" class="text-muted transition-colors hover:text-blue">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M14 8h3V5h-3a4 4 0 0 0-4 4v2H7v3h3v7h3v-7h3l1-3h-4V9a1 1 0 0 1 1-1z"/></svg>
        </a>
    </li>
</ul>

<div class="mt-6 text-base leading-relaxed text-muted">
    {%- for paragraph in intro %}
        <p class="mb-3">{{ paragraph }}</p>
    {%- endfor -%}
</div>

<div class="mt-6">
    <p class="cap-label text-soft">{{ message }}</p>
    <a class="link-underline text-sm" href="mailto:{{ global.contact.email }}">{{ global.contact.email }}</a>
</div>

<div class="mt-6">
    <p class="cap-label text-soft">{{ phone }}</p>
    <a class="link-underline text-sm" href="tel:{{ global.contact.phone }}">{{ global.contact.phone }}</a>
</div>

<div class="mt-6">
    <p class="cap-label text-soft">{{ address }}</p>
    <p class="mt-1 text-base text-muted">{{ global.contact.address | nl2br | safe }}</p>
</div>

<div id="map" class="mt-6 overflow-hidden rounded-xl">
    {{ gmaps | safe }}
</div>
