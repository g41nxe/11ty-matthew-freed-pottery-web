<section class="bg-blue" aria-label="Upcoming events">
    <div class="mx-auto max-w-6xl px-6 py-12">
        <div class="flex items-baseline justify-between gap-4">
            <h2 class="font-display text-3xl font-black text-paper">{{ events_band.title }}</h2>
            <a href="/events.html" class="whitespace-nowrap border-b border-sand pb-0.5 text-sm font-medium text-sand">All events</a>
        </div>
        {% set upcoming = events.events | filterFuture | nextUp %}
        {% if upcoming.length %}
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {% for event in upcoming %}
            {% if loop.index <= 4 %}
            <a href="/events.html" class="group rounded-xl border border-blue-light p-5 transition-colors hover:bg-blue-light">
                <p class="flex items-baseline gap-2">
                    <span class="font-display text-3xl font-black text-paper">{{ event.date | date("d") }}</span>
                    <span class="cap-label text-[11px] text-sand">{{ event.date | date("MMM") }}</span>
                </p>
                <p class="mt-3 font-display text-base font-black leading-snug text-paper">
                    {{ event.name }}
                </p>
                <p class="mt-1 text-sm text-paper/70">{{ event.location }}</p>
                {% if event.atStudio %}<p class="cap-label mt-2 text-[11px] text-sand">At my studio</p>{% endif %}
            </a>
            {% endif %}
            {% endfor %}
        </div>
        {% else %}
        <p class="mt-6 max-w-xl text-base text-paper/80">{{ events_band.no_events }}</p>
        {% endif %}
    </div>
</section>
