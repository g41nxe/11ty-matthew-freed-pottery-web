<section class="ca-wrap ca-ev-sec">
  <div class="ca-shead"><span class="ca-idx">05</span><h2 class="ca-disp">{{ event.title }}</h2></div>
  {% set upcoming = events.events | filterFeatured %}
  {% if upcoming | length %}
  <div class="ca-ev-list">
    {%- for entry in upcoming -%}
    <div class="ca-ev-item">
      <button class="ca-ev" aria-expanded="false">
        <span class="ca-ev-date">{{ entry.date | date('MMM d') }}{% if entry.multi_day_event %} &ndash; {{ entry.end_date | date('MMM d') }}{% endif %}</span>
        <span class="ca-ev-info"><span class="ca-ev-title">{{ entry.name | trim }}</span><span>{{ entry.location | trim }} &middot; {{ entry.time | trim }}</span></span>
        <span class="ca-chev">&#9662;</span>
      </button>
      <div class="ca-ev-detail"><div class="ca-ev-detail-in">
        <p>{{ entry.content.body | trim }}</p>
        <p style="margin-top:8px">{{ entry.location | trim }} &middot; <a href="https://maps.google.com/?q={{ entry.gmaps | urlencode }}" target="_blank" rel="noopener">Get directions &#8599;</a></p>
      </div></div>
    </div>
    {%- endfor -%}
  </div>
  {% else %}
  <p class="ca-ev-empty">{{ event.no_events.title }}</p>
  {% endif %}
  <div class="ca-coll-more"><a class="ca-show-all" href="/updates/">See all events &rarr;</a></div>
</section>
