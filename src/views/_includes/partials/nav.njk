{# Active-page detection: About stays active on its subpages (/about/process etc.) #}
{% set navItems = [
    { href: "/collections.html", label: "Collections", active: page.url == "/collections.html" },
    { href: "/events.html", label: "Events", active: page.url == "/events.html" },
    { href: "/about/", label: "About", active: "/about/" in page.url },
    { href: "/contact.html", label: "Contact", active: page.url == "/contact.html" }
] %}
<header id="site-header" class="sticky top-0 z-40 border-b border-transparent bg-paper transition-colors duration-300">
    <div class="site-nav-bar mx-auto flex max-w-6xl items-center justify-between px-6 py-4 transition-[padding] duration-300">
        <a href="/" class="mr-3 whitespace-nowrap font-display text-lg font-black text-blue sm:text-xl"><span class="sm:hidden">Matthew Freed</span><span class="hidden sm:inline">Matthew Freed Pottery</span></a>

        <nav class="hidden items-center gap-8 md:flex" aria-label="Main">
            {% for item in navItems %}
            <a href="{{ item.href }}"{% if item.active %} aria-current="page"{% endif %} class="nav-link text-base {% if item.active %}text-blue{% else %}text-muted{% endif %} transition-colors hover:text-blue">{{ item.label }}</a>
            {% endfor %}
            <a href="{{ global.shop.base }}{{ global.shop.collectionsPath }}/" target="_blank" rel="noopener" class="btn-primary px-5 py-2 text-sm">Shop</a>
        </nav>

        <div class="flex items-center gap-3 md:hidden">
            <a href="{{ global.shop.base }}{{ global.shop.collectionsPath }}/" target="_blank" rel="noopener" class="btn-primary px-5 py-2.5 text-sm">Shop</a>
            <button id="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Menu" class="flex h-11 w-11 items-center justify-center text-ink">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                    <line class="nav-line-top" x1="3" y1="6" x2="21" y2="6"/>
                    <line class="nav-line-mid" x1="3" y1="12" x2="21" y2="12"/>
                    <line class="nav-line-bot" x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>
        </div>
    </div>

    <nav id="nav-menu" hidden class="border-t border-hairline px-6 py-4 md:hidden" aria-label="Main mobile">
        {% for item in navItems %}
        <a href="{{ item.href }}"{% if item.active %} aria-current="page"{% endif %} class="block py-3 text-base {% if item.active %}font-medium text-blue{% else %}text-ink{% endif %}">{{ item.label }}</a>
        {% endfor %}
    </nav>
</header>
