<div id="nav" class="ca-nav-wrap">
  <div class="ca-nav">
    <a href="/" class="ca-logo ca-disp">Matthew Freed</a>

    <nav role="navigation" aria-label="Main" id="desktop--menu" class="ca-nav-links">
      {% set navPages = collections.all | eleventyNavigation %}
      {%- for entry in navPages %}{% if entry.title and entry.url != "/" %}
        <a class="{{ 'is-active' if entry.url == page.url }}" href="{{ entry.url | url }}">{{ entry.title }}</a>
      {% endif %}{%- endfor %}
      <a class="ca-nav-ig" target="_blank" rel="noopener" aria-label="Instagram" href="{{ global.socialmedia.services.instagram.url | url }}"><i class="fab fa-instagram"></i></a>
      <a class="ca-shop-btn" target="_blank" rel="noopener" href="{{ global.shop.url | url }}">Shop</a>
    </nav>

    <button id="mobile--btn" class="ca-mobile-btn" aria-label="Open menu"><i class="fa-2x fas fa-bars"></i></button>
  </div>

  <nav role="navigation" aria-label="Mobile" id="mobile--menu" class="flex absolute w-full bg-brand justify-center items-center">
    <ul class="flex flex-col justify-center items-center text-center py-4">
      {% set navPages = collections.all | eleventyNavigation %}
      {%- for entry in navPages %}{% if entry.title and entry.url != "/" %}
        <li class="py-4"><a href="{{ entry.url | url }}" class="text-xl px-8 text-gray-light hover:text-highlight {{ 'font-bold' if entry.url == page.url }}">{{ entry.title }}</a></li>
      {% endif %}{%- endfor %}
      <li class="py-4"><a target="_blank" rel="noopener" href="{{ global.socialmedia.services.instagram.url | url }}" class="text-xl px-8 text-gray-light hover:text-highlight">Instagram</a></li>
      <li class="py-4"><a target="_blank" rel="noopener" href="{{ global.shop.url | url }}" class="text-xl px-8 text-highlight">Shop</a></li>
    </ul>
  </nav>
</div>
