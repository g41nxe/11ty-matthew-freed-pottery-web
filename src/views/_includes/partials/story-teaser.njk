<section class="bg-blue" aria-label="About Matthew">
    <div class="mx-auto grid max-w-6xl md:grid-cols-2">
        <div class="relative aspect-[4/3] overflow-hidden md:aspect-auto">
            {% img story_teaser.image.url, story_teaser.image.alt, "(min-width: 768px) 50vw, 100vw", "absolute inset-0 h-full w-full object-cover" %}
        </div>
        <div class="flex flex-col items-start justify-center px-6 py-12 md:px-12 md:py-14">
            {% if story_teaser.eyebrow %}<p class="cap-label text-sand">{{ story_teaser.eyebrow }}</p>{% endif %}
            <h2 class="mt-3 font-display text-3xl font-black leading-tight text-paper">{{ story_teaser.title }}</h2>
            <p class="mt-4 max-w-md text-base leading-relaxed text-paper/80">{{ story_teaser.text }}</p>
            {% if story_teaser.quote %}
            <p class="mt-6 border-l-2 border-sand pl-4 font-display text-xl leading-snug text-paper">&ldquo;{{ story_teaser.quote }}&rdquo;</p>
            {% endif %}
            <a href="/about/" class="link-underline link-invert mt-8 inline-block text-sm">{{ story_teaser.label }}</a>
        </div>
    </div>
</section>
