<h2 class="font-display text-2xl font-black text-ink">{{ contactform.title }}</h2>

<p class="mb-4 mt-2 text-sm text-soft">{{ contactform.info }}</p>

<form name="contact" id="contact_form" method="POST" action="/success"
      netlify-honeypot="bot-field" data-netlify="true" data-netlify-recaptcha="true">

    <p class="hidden">
        <label>Don’t fill this out if you're human: <input name="bot-field" /></label>
    </p>

    <label class="sr-only" for="contact_name">Name</label>
    <input id="contact_name" name="name" type="text" placeholder="Name"
            class="mb-4 w-full rounded-lg border border-hairline bg-white px-4 py-3 text-base text-ink placeholder:text-soft focus:border-blue focus:outline-none"
    />

    <label class="sr-only" for="email">Email</label>
    <input id="email" name="email" type="text" placeholder="Email *" required
           class="mb-4 w-full rounded-lg border border-hairline bg-white px-4 py-3 text-base text-ink placeholder:text-soft focus:border-blue focus:outline-none"
    />

    <label class="sr-only" for="contact_phone">Phone</label>
    <input id="contact_phone" name="phone" type="text" placeholder="Phone"
           class="mb-4 w-full rounded-lg border border-hairline bg-white px-4 py-3 text-base text-ink placeholder:text-soft focus:border-blue focus:outline-none"
    />

    <label class="sr-only" for="contact_message">Message</label>
    <textarea id="contact_message" name="message" placeholder="What's on your mind? *" required
              class="mb-4 w-full rounded-lg border border-hairline bg-white px-4 py-3 text-base text-ink placeholder:text-soft focus:border-blue focus:outline-none md:h-48"
    ></textarea>

    <div data-netlify-recaptcha="true" class="mb-4"></div>

    <button aria-label="Send" type="submit" class="btn-primary">
        {{ contactform.submit }}
    </button>

</form>
