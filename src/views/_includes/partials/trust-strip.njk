<section class="border-y border-hairline bg-white" aria-label="Why buy from Matthew">
    <ul class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-4 gap-y-2 px-6 py-5 md:justify-between md:gap-x-8">
        {% for item in trust %}
        {% if not loop.first %}
        <li aria-hidden="true" class="hidden text-sand md:block">
            <svg viewBox="0 0 40 40" width="13" height="13" fill="currentColor"><ellipse cx="20" cy="9" rx="6" ry="9"/><ellipse cx="20" cy="31" rx="6" ry="9"/><ellipse cx="9" cy="20" rx="9" ry="6"/><ellipse cx="31" cy="20" rx="9" ry="6"/></svg>
        </li>
        {% endif %}
        <li class="cap-label text-[12px] text-ink">{{ item }}</li>
        {% endfor %}
    </ul>
</section>
