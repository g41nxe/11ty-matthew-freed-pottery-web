{% include "newsletter.njk" %}
<footer class="bg-ink text-paper">
    <div class="mx-auto flex max-w-6xl flex-col gap-6 px-6 py-10 md:flex-row md:items-start md:justify-between">
        <div>
            <p class="flex items-center gap-2.5 font-display text-lg font-black">
                <span class="text-sand" aria-hidden="true"><svg viewBox="0 0 40 40" width="18" height="18" fill="currentColor"><ellipse cx="20" cy="9" rx="6" ry="9"/><ellipse cx="20" cy="31" rx="6" ry="9"/><ellipse cx="9" cy="20" rx="9" ry="6"/><ellipse cx="31" cy="20" rx="9" ry="6"/><circle cx="20" cy="20" r="4" fill="#2A2822"/></svg></span>
                Matthew Freed Pottery
            </p>
            <p class="mt-2 text-sm text-soft">{{ global.contact.address | nl2br | safe }}</p>
            <p class="mt-2 text-sm text-soft">
                {{ global.contact.text | safe
                    | replace("<mail>", "<a class=\"underline hover:text-sand\" href=\"mailto:" + global.contact.email + "\">")
                    | replace("<phone>", "<a class=\"underline hover:text-sand\" href=\"tel:" + global.contact.phone + "\">")
                    | replace("</mail>", "</a>")
                    | replace("</phone>", "</a>" )
                }}
            </p>
        </div>
        <nav class="flex flex-col gap-2 text-sm" aria-label="Footer">
            <a href="/retail-stores.html" class="text-soft transition-colors hover:text-sand">Retail stores</a>
            <a href="/faq.html" class="text-soft transition-colors hover:text-sand">FAQ</a>
            <a href="/about/process.html" class="text-soft transition-colors hover:text-sand">My process</a>
            <a href="/privacy-statement.html" class="text-soft transition-colors hover:text-sand">Privacy</a>
        </nav>
        <div class="flex gap-4">
            <a href="{{ global.socialmedia.services.instagram.url }}" target="_blank" aria-label="Instagram" class="text-soft transition-colors hover:text-sand">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="0.8" fill="currentColor"/></svg>
            </a>
            <a href="{{ global.socialmedia.services.facebook.url }}" target="_blank" aria-label="Facebook" class="text-soft transition-colors hover:text-sand">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M14 8h3V5h-3a4 4 0 0 0-4 4v2H7v3h3v7h3v-7h3l1-3h-4V9a1 1 0 0 1 1-1z"/></svg>
            </a>
        </div>
    </div>
    <div class="border-t border-blue-light/30 px-6 py-4 text-center text-xs text-soft">
        © Matthew Freed Pottery
    </div>
</footer>
